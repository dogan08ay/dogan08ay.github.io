export default async function handler(req, res) {
  // Sadece POST isteklerini kabul et
  if (req.method !== 'POST') {
    return res.status(405).send('Method Not Allowed');
  }

  const { action, paymentId } = req.body;

  // Pi Network'ten gelen "payment_prepared" isteğini doğrula
  if (action === 'payment_prepared') {
    try {
      const apiKey = process.env.PI_API_KEY;

      // Pi Network'e ödemeyi onaylama isteği gönder
      const response = await fetch(`https://api.minepi.com/v2/payments/${paymentId}/approve`, {
        method: 'POST',
        headers: {
          'Authorization': `Key ${apiKey}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({}),
      });

      if (response.ok) {
        // İşlem başarıyla onaylandı
        return res.status(200).json({ status: 'approved' });
      } else {
        const errorData = await response.json();
        console.error('Pi API Hatası:', errorData);
        return res.status(500).json({ error: 'Ödeme onaylanamadı' });
      }
    } catch (error) {
      console.error('Sunucu Hatası:', error);
      return res.status(500).json({ error: 'İç sunucu hatası' });
    }
  }

  return res.status(400).send('Geçersiz işlem');
}
